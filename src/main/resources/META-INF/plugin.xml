<idea-plugin>
    <!-- Unique id for this plugin. -->
    <id>dev.sivalabs.springup.plugin</id>
    <!-- Text to display as the name on Settings | Plugin page -->
    <name>SpringUp</name>
    <!-- Text to display as company information on Settings | Plugin page -->
    <vendor url="https://sivalabs.dev">SivaLabs</vendor>

    <!-- Product and plugin compatibility requirements -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <!-- Text to display as a description on the Settings | Plugin page -->
    <description>
        <![CDATA[
            Helps Spring Boot application development by:
            — Generating CRUD REST APIs from JPA/JDBC Entities
        ]]>
    </description>
    <change-notes>
        <![CDATA[
      <ul>
        <li><b>1.0.0</b> Initial Release.</li>
      </ul>
    ]]>
    </change-notes>

    <actions>
        <action
                id="CrudGenerator.GenerateCrudAction"
                class="dev.sivalabs.springup.plugin.GenerateCrudAction"
                text="Generate CRUD"
                description="Generate Controller, Service, Repository, and DTOs for a JPA Entity">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">

    </extensions>

</idea-plugin>
